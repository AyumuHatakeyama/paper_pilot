# ================================================================
# OTAYORI NAVI — 環境変数テンプレート
# このファイルをコピーして .env.local を作成し、値を埋めてください。
# .env.local は絶対にGitにコミットしないこと。
# ================================================================

# ----------------------------------------------------------------
# Supabase
# ----------------------------------------------------------------
# Supabase ダッシュボード → Project Settings → API で確認
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ----------------------------------------------------------------
# Anthropic (Claude API)
# ----------------------------------------------------------------
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ----------------------------------------------------------------
# LINE Messaging API
# ----------------------------------------------------------------
# LINE Developers → チャンネル → Messaging API設定 で確認
LINE_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINE_CHANNEL_ACCESS_TOKEN=xxxxxx...

# ----------------------------------------------------------------
# 許可するLINEユーザーID（カンマ区切り、2名分）
# ----------------------------------------------------------------
# LINE Developers → チャンネル → Messaging API設定 → 「あなたのユーザーID」で確認
# または LINE Official Account Manager で確認
ALLOWED_LINE_USER_IDS=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx,Uyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# ----------------------------------------------------------------
# Webアプリ（Phase 2）
# ----------------------------------------------------------------
# Vercelデプロイ後のURL
WEB_APP_URL=https://your-app.vercel.app

# LIFF ID（LINE DevelopersでLIFFアプリを追加後に取得）
LIFF_ID=xxxxxxxxxx-xxxxxxxx
