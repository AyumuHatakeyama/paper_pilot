# deno testでのみ使うダミー値。webhook-line/clients.ts等がモジュール読み込み時に
# createClient()/new Anthropic()を呼ぶため、実際のAPIを叩かないテストでも値だけは必要。
# 実行例: deno test --allow-env --env-file=supabase/functions/.env.test supabase/functions
SUPABASE_URL=https://example.supabase.co
SUPABASE_SERVICE_ROLE_KEY=dummy-service-role-key
ANTHROPIC_API_KEY=dummy-anthropic-key
LINE_CHANNEL_ACCESS_TOKEN=dummy-line-access-token
LINE_CHANNEL_SECRET=dummy-line-secret
WEB_APP_URL=https://example-app.vercel.app
